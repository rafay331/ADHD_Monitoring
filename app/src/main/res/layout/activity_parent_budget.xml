<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F6F7FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parentBudgetRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarParentBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:title="Parent Budget"
            app:titleTextColor="#111827"
            app:navigationIconTint="#111827"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Overview Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardParentOverview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/toolbarParentBudget"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvParentOverviewTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Budget Overview"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressParentBudget"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="12dp"
                    app:trackCornerRadius="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvParentOverviewTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvParentSpentLimit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="0 / 0"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/progressParentBudget"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvParentAlert"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Status: On Track"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@id/tvParentSpentLimit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvBudgetMonth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Month: Jan 2026"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/tvParentAlert"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Controls Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardParentControls"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardParentOverview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvControlsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Parent Controls"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMonthlyLimit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Monthly Limit (e.g., 20000)"
                    app:layout_constraintTop_toBottomOf="@id/tvControlsTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMonthlyLimit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveLimit"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:text="Save Monthly Limit"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/tilMonthlyLimit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:id="@+id/rowLockToggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnSaveLimit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tvLockLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enable Budget Lock (Auto-lock when limit exceeded)"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchBudgetLock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- ONLY remaining action -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnParentReports"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:text="Generate Expense Report"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/rowLockToggle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Expenses -->
        <TextView
            android:id="@+id/tvParentRecentTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Recent Expenses"
            android:textStyle="bold"
            android:textColor="#111827"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardParentControls"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvParentRecent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvParentRecentTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
